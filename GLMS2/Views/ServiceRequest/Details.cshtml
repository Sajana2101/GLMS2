@model GLMS2.Models.ServiceRequest

<h2>Service Request Details</h2>

<div>
    <p><strong>Client:</strong> @Model.Contract?.Client?.Name</p>
    <p><strong>Contract ID:</strong> @Model.ContractId</p>
    <p><strong>Description:</strong> @Model.Description</p>
    <p><strong>Cost (USD):</strong> @Model.CostUSD</p>
    <p><strong>Cost (ZAR):</strong> @Model.CostZAR</p>
    <p><strong>Status:</strong> @Model.Status</p>
    <p><strong>Created Date:</strong> @Model.CreatedDate.ToShortDateString()</p>
</div>

<p>
    <a asp-action="Index">Back to List</a>
</p>