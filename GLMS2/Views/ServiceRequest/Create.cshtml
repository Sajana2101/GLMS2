@model GLMS2.ViewModels.ServiceRequestCreateViewModel

<h2>Create Service Request</h2>

<form asp-action="Create" method="post">
    <!-- Displays validation errors -->
    <div asp-validation-summary="All" class="text-danger"></div>
    <!-- Displays API error if exchange rate fails -->
    @if (ViewBag.ApiError != null)
    {
        <div class="text-danger">
            @ViewBag.ApiError
        </div>
    }

    <div>
        <!-- Select contract linked to service request -->
        <label asp-for="ContractId"></label>
        <select asp-for="ContractId" asp-items="ViewBag.Contracts"></select>
        <span asp-validation-for="ContractId" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Description"></label>
        <input asp-for="Description" />
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div>
        <!-- Cost entered in USD -->
        <label asp-for="CostUSD"></label>
        <input asp-for="CostUSD" id="costUsdInput" type="number" step="0.01" />
        <span asp-validation-for="CostUSD" class="text-danger"></span>
    </div>

    <div>
        <!-- Exchange rate retrieved from API -->
        <label asp-for="ExchangeRate"></label>
        <input id="exchangeRateInput" value="@Model.ExchangeRate" readonly />
    </div>

    <div>
        <!-- Converted cost displayed in ZAR -->
        <label asp-for="CostZAR"></label>
        <input id="costZarInput" readonly />
    </div>

    <button type="submit">Create</button>
</form>

<p>
    <a asp-action="Index">Back to List</a>
</p>

<script>
     // Automatically converts USD to ZAR using exchange rate
    const usdInput = document.getElementById('costUsdInput');
    const rateInput = document.getElementById('exchangeRateInput');
    const zarInput = document.getElementById('costZarInput');

    function calculateZar() {
        const usd = parseFloat(usdInput.value) || 0;
        const rate = parseFloat(rateInput.value) || 0;
        zarInput.value = (usd * rate).toFixed(2);
    }

    usdInput.addEventListener('input', calculateZar);
</script>