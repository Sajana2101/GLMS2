@model GLMS2.Models.Client

@{
    ViewData["Title"] = "Client Details";
}

<h1>Client Details</h1>

<div>
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Name</dd>

        <dt class="col-sm-2">Region</dt>
        <dd class="col-sm-10">@Model.Region</dd>

        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.Email</dd>
    </dl>
</div>

@if (Model.Contracts != null && Model.Contracts.Any())
{
    <h3>Contracts</h3>
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Contract ID</th>
                <th>Status</th>
                <th>Service Level</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var contract in Model.Contracts)
            {
                <tr>
                    <td>@contract.ContractId</td>
                    <td>@contract.Status</td>
                    <td>@contract.ServiceLevel</td>
                </tr>
            }
        </tbody>
    </table>
}

<a asp-action="Edit" asp-route-id="@Model.ClientId" class="btn btn-primary">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back</a>